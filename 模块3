        elements.layerList.querySelectorAll("[data-layer-id]").forEach((node) => {
          const layerId = node.dataset.layerId;
          node.querySelector(".layer-select").addEventListener("click", () => setSelectedLayer(layerId));

          node.querySelector(".layer-toggle").addEventListener("click", () => {
            pushHistory();
