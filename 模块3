      const appState = {
        lang: "zh",
        activeView: "2d",
        selectionMode: false,
        sourceImageUrl: null,
        sourceImage: null,
        imagePlacement: null,
        layers: [],
        selectedLayerId: null,
        history: [],
        future: [],
        status: "",
        skipHistory: false
      };

      const elements = {
        importBtn: document.getElementById("importBtn"),
        aiBtn: document.getElementById("aiBtn"),
        manualBtn: document.getElementById("manualBtn"),
        view2dBtn: document.getElementById("view2dBtn"),
        view3dBtn: document.getElementById("view3dBtn"),
        tab2dBtn: document.getElementById("tab2dBtn"),
        tab3dBtn: document.getElementById("tab3dBtn"),
        exportBtn: document.getElementById("exportBtn"),
        floatingExportBtn: document.getElementById("floatingExportBtn"),
        snapshotBtn: document.getElementById("snapshotBtn"),
        langBtn: document.getElementById("langBtn"),
        fileInput: document.getElementById("fileInput"),
        editor2dSection: document.getElementById("editor2dSection"),
        preview3dSection: document.getElementById("preview3dSection"),
        propertyPanel: document.getElementById("propertyPanel"),
        propertyDescription: document.getElementById("propertyDescription"),
        layerList: document.getElementById("layerList"),
        layerSummary: document.getElementById("layerSummary"),
        usageText: document.getElementById("usageText"),
        canvasStateText: document.getElementById("canvasStateText"),
        canvasHintText: document.getElementById("canvasHintText"),
        statusText: document.getElementById("statusText"),
        dropZone: document.getElementById("dropZone"),
        dropOverlay: document.getElementById("dropOverlay"),
        dropOverlayText: document.getElementById("dropOverlayText"),
        emptyCanvasOverlay: document.getElementById("emptyCanvasOverlay"),
        emptyPreviewOverlay: document.getElementById("emptyPreviewOverlay"),
        threeContainer: document.getElementById("threeContainer")
      };

      const CANVAS_WIDTH = 920;
      const CANVAS_HEIGHT = 560;
      const PHONE_WIDTH = 5;
      const PHONE_HEIGHT = 9.6;

      const fabricCanvas = new fabric.Canvas("editorCanvas", {
        width: CANVAS_WIDTH,
        height: CANVAS_HEIGHT,
        backgroundColor: "#09090b",
        selection: false,
        preserveObjectStacking: true
      });

      let backgroundFabricImage = null;
      let activeSelectionRect = null;
      let dragStartPoint = null;
      let isSelecting = false;
      const layerOverlayMap = new Map();

      const threeState = {
        renderer: null,
        scene: null,
        camera: null,
        controls: null,
        previewRoot: null,
        rootGroup: null
      };

      function t(path) {
        return path.split(".").reduce((acc, key) => acc && acc[key], I18N[appState.lang]) || path;
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function cloneLayers(layers) {
        return JSON.parse(JSON.stringify(layers));
      }

      function createSnapshot() {
        return {
          layers: cloneLayers(appState.layers),
          selectedLayerId: appState.selectedLayerId
        };
      }

      function pushHistory() {
        if (appState.skipHistory) {
          return;
        }
        appState.history.push(createSnapshot());
        if (appState.history.length > 100) {
          appState.history.shift();
        }
        appState.future = [];
      }

      function setStatus(text) {
        appState.status = text;
        elements.statusText.textContent = text || t("status.ready");
      }

      function setActiveView(view) {
        appState.activeView = view;
        const is2d = view === "2d";
        elements.editor2dSection.classList.toggle("hidden", !is2d);
        elements.preview3dSection.classList.toggle("hidden", is2d);

        [elements.view2dBtn, elements.tab2dBtn].forEach((button) => {
          button.className = is2d
            ? "rounded-xl border border-sky-500 bg-sky-500 px-4 py-2 text-sm text-white transition hover:bg-sky-400"
            : "rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800";
        });

        [elements.view3dBtn, elements.tab3dBtn].forEach((button) => {
          button.className = !is2d
            ? "rounded-xl border border-sky-500 bg-sky-500 px-4 py-2 text-sm text-white transition hover:bg-sky-400"
            : "rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800";
        });
      }

      function setSelectionMode(active) {
        appState.selectionMode = active;
        elements.manualBtn.className = active
          ? "rounded-xl border border-sky-500 bg-sky-500 px-4 py-2 text-sm text-white transition hover:bg-sky-400"
          : "rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800";
        renderStaticText();
      }

      function applyLanguage() {
        document.documentElement.lang = appState.lang === "zh" ? "zh-CN" : "en";
        document.querySelectorAll("[data-i18n]").forEach((node) => {
          node.textContent = t(node.dataset.i18n);
        });
        elements.langBtn.textContent = appState.lang === "zh" ? "🌐 ZH" : "🌐 EN";
        elements.usageText.textContent = t("usage.text");
        renderAll();
      }

      function setLanguage(lang) {
        appState.lang = lang;
        applyLanguage();
      }

      function getSelectedLayer() {
        return appState.layers.find((layer) => layer.id === appState.selectedLayerId) || null;
      }

      function setSelectedLayer(layerId) {
        appState.selectedLayerId = layerId;
        renderAll();
      }

      function getContainPlacement(imageWidth, imageHeight, maxWidth, maxHeight) {
        const scale = Math.min(maxWidth / imageWidth, maxHeight / imageHeight);
        const width = imageWidth * scale;
        const height = imageHeight * scale;
        return {
          left: (maxWidth - width) / 2,
          top: (maxHeight - height) / 2,
          width,
          height,
          originalWidth: imageWidth,
          originalHeight: imageHeight
        };
      }

      function clamp(value, min, max) {
        return Math.min(Math.max(value, min), max);
      }

      function makeId() {
        if (window.crypto && crypto.randomUUID) {
          return crypto.randomUUID();
        }
        return "layer-" + Date.now() + "-" + Math.random().toString(36).slice(2);
      }

      function removeActiveSelection() {
        if (activeSelectionRect) {
          fabricCanvas.remove(activeSelectionRect);
          activeSelectionRect = null;
          fabricCanvas.requestRenderAll();
        }
      }

      function clearOverlayRects() {
        layerOverlayMap.forEach((rect) => {
          fabricCanvas.remove(rect);
        });
        layerOverlayMap.clear();
      }

      function refreshFabricOverlays() {
        const activeIds = new Set(appState.layers.map((layer) => layer.id));
        layerOverlayMap.forEach((rect, layerId) => {
          if (!activeIds.has(layerId)) {
            fabricCanvas.remove(rect);
            layerOverlayMap.delete(layerId);
          }
        });

        appState.layers.forEach((layer) => {
          let rect = layerOverlayMap.get(layer.id);
          if (!rect) {
            rect = new fabric.Rect({
              left: layer.left,
              top: layer.top,
              width: layer.width,
              height: layer.height,
              fill: "rgba(255,255,255,0.04)",
              stroke: "#71717a",
              strokeDashArray: [6, 5],
              selectable: false,
              evented: true,
              rx: 12,
              ry: 12
            });
            rect.on("mousedown", () => {
              setSelectedLayer(layer.id);
            });
            layerOverlayMap.set(layer.id, rect);
            fabricCanvas.add(rect);
          }

          rect.set({
            left: layer.left,
            top: layer.top,
            width: layer.width,
            height: layer.height,
            visible: layer.visible,
            evented: layer.visible,
            fill: layer.id === appState.selectedLayerId ? "rgba(56,189,248,0.18)" : "rgba(255,255,255,0.04)",
            stroke: layer.id === appState.selectedLayerId ? "#38bdf8" : "#71717a"
          });
          rect.setCoords();
          rect.bringToFront();
        });

        if (activeSelectionRect) {
          activeSelectionRect.bringToFront();
        }
        fabricCanvas.requestRenderAll();
      }

