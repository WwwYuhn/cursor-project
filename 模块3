              const next = [...appState.layers];
              [next[index], next[index + 1]] = [next[index + 1], next[index]];
              appState.layers = next;
              renderAll();
            }
          });
        });
      }

      function getMaterialPreset(material) {
        if (material === "matte") {
          return {
            color: 0x5b5b65,
            specular: 0x111111,
            shininess: 15,
            opacity: 1,
            transparent: false
          };
        }
        if (material === "glass") {
          return {
            color: 0xbfe6ff,
            specular: 0xffffff,
            shininess: 95,
            opacity: 0.62,
            transparent: true
          };
        }
        if (material === "metal") {
          return {
            color: 0xb0b7c3,
            specular: 0xffffff,
            shininess: 90,
            opacity: 1,
            transparent: false
          };
        }
        return {
          color: 0xe4e4e7,
          specular: 0xffffff,
          shininess: 65,
          opacity: 1,
          transparent: false
        };
      }

      function createRoundedBoxGeometry(width, height, depth, radius, bevelStrength) {
        const safeWidth = Math.max(width, 0.02);
        const safeHeight = Math.max(height, 0.02);
        const safeDepth = Math.max(depth, 0.02);
        const maxRadius = Math.max(Math.min(safeWidth, safeHeight, safeDepth) * 0.45, 0);
        const safeRadius = clamp(radius, 0, maxRadius);
        const segments = Math.max(1, Math.round(2 + bevelStrength));

        const geometry = new THREE.BoxGeometry(
          safeWidth,
          safeHeight,
          safeDepth,
          segments * 2,
          segments * 2,
          segments * 2,
        );

        if (safeRadius <= 0) {
          return geometry;
        }

        const position = geometry.attributes.position;
        const vertex = new THREE.Vector3();
        const inner = new THREE.Vector3(
          safeWidth / 2 - safeRadius,
          safeHeight / 2 - safeRadius,
          safeDepth / 2 - safeRadius,
        );

        for (let i = 0; i < position.count; i += 1) {
          vertex.fromBufferAttribute(position, i);

          const clamped = new THREE.Vector3(
            clamp(vertex.x, -inner.x, inner.x),
            clamp(vertex.y, -inner.y, inner.y),
            clamp(vertex.z, -inner.z, inner.z),
          );

          const delta = vertex.clone().sub(clamped);
          if (delta.lengthSq() > 0) {
            delta.normalize().multiplyScalar(safeRadius);
            vertex.copy(clamped.add(delta));
          } else {
            vertex.copy(clamped);
          }

          position.setXYZ(i, vertex.x, vertex.y, vertex.z);
        }

        geometry.computeVertexNormals();
        return geometry;
      }

      function initThree() {
        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true, preserveDrawingBuffer: true });
        renderer.setPixelRatio(window.devicePixelRatio);
        renderer.setSize(elements.threeContainer.clientWidth || 900, elements.threeContainer.clientHeight || 680);
        renderer.shadowMap.enabled = true;
        elements.threeContainer.appendChild(renderer.domElement);

        const scene = new THREE.Scene();
        scene.background = new THREE.Color("#09090b");

        const camera = new THREE.PerspectiveCamera(40, (elements.threeContainer.clientWidth || 900) / 680, 0.1, 100);
        camera.position.set(0, 0.4, 12);

        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.enablePan = false;

        const ambient = new THREE.AmbientLight(0xffffff, 1.35);
        const key = new THREE.DirectionalLight(0xffffff, 1.8);
        key.position.set(5, 6, 8);
        key.castShadow = true;
        const fill = new THREE.PointLight(0x38bdf8, 50, 40);
        fill.position.set(-5, 3, 5);

        const floor = new THREE.Mesh(
          new THREE.PlaneGeometry(40, 40),
          new THREE.ShadowMaterial({ opacity: 0.18 }),
        );
        floor.rotation.x = -Math.PI / 2;
        floor.position.y = -6;
        floor.receiveShadow = true;

        const rootGroup = new THREE.Group();

        scene.add(ambient, key, fill, floor, rootGroup);

        function animate() {
          controls.update();
          renderer.render(scene, camera);
          requestAnimationFrame(animate);
        }
        animate();

        window.addEventListener("resize", () => {
          const width = elements.threeContainer.clientWidth || 900;
          const height = elements.threeContainer.clientHeight || 680;
          camera.aspect = width / height;
          camera.updateProjectionMatrix();
          renderer.setSize(width, height);
        });

        threeState.renderer = renderer;
        threeState.scene = scene;
        threeState.camera = camera;
        threeState.controls = controls;
        threeState.rootGroup = rootGroup;
      }

      function disposeGroup(group) {
        while (group.children.length > 0) {
          const child = group.children[0];
          group.remove(child);
          if (child.geometry) {
            child.geometry.dispose();
          }
          if (child.material) {
            if (Array.isArray(child.material)) {
              child.material.forEach((item) => item.dispose && item.dispose());
            } else if (child.material.dispose) {
              child.material.dispose();
            }
          }
          if (child.children?.length) {
            disposeGroup(child);
          }
        }
      }

      function buildPreviewScene() {
        if (!threeState.rootGroup) {
          return;
        }

        disposeGroup(threeState.rootGroup);

        const deviceGeometry = createRoundedBoxGeometry(5.7, 10.4, 0.35, 0.22, 8);
        const deviceMaterial = new THREE.MeshPhongMaterial({
          color: 0x121318,
          specular: 0x3b3f48,
          shininess: 45
        });
        const deviceMesh = new THREE.Mesh(deviceGeometry, deviceMaterial);
        deviceMesh.position.z = -0.2;
        deviceMesh.castShadow = true;
        deviceMesh.receiveShadow = true;
        threeState.rootGroup.add(deviceMesh);

        const textureLoader = new THREE.TextureLoader();

        if (appState.sourceImageUrl) {
          const baseTexture = textureLoader.load(appState.sourceImageUrl);
          baseTexture.colorSpace = THREE.SRGBColorSpace;
          const basePlane = new THREE.Mesh(
            new THREE.PlaneGeometry(PHONE_WIDTH, PHONE_HEIGHT),
            new THREE.MeshBasicMaterial({ map: baseTexture, transparent: true }),
          );
          basePlane.position.z = 0.01;
          threeState.rootGroup.add(basePlane);
        }

        appState.layers
          .filter((layer) => layer.visible)
          .forEach((layer) => {
            const depth = Math.max(layer.thickness / 60, 0.06);
            const bevel = layer.bevel;
            const radius = Math.min(layer.radius / 60, Math.min(layer.width3d, layer.height3d, depth) * 0.45);
            const preset = getMaterialPreset(layer.material);

            const bodyMaterial = new THREE.MeshPhongMaterial({
              color: preset.color,
              specular: preset.specular,
              shininess: preset.shininess + bevel * 2,
              opacity: preset.opacity,
              transparent: preset.transparent
            });

            const geometry = createRoundedBoxGeometry(
              Math.max(layer.width3d, 0.08),
              Math.max(layer.height3d, 0.08),
              depth,
              radius,
              bevel,
            );

            const body = new THREE.Mesh(geometry, bodyMaterial);
            body.position.set(layer.x, layer.y, depth / 2 + 0.05);
            body.castShadow = true;
            body.receiveShadow = true;
            threeState.rootGroup.add(body);

            const texture = textureLoader.load(layer.textureUrl);
            texture.colorSpace = THREE.SRGBColorSpace;
            const face = new THREE.Mesh(
              new THREE.PlaneGeometry(layer.width3d * 0.97, layer.height3d * 0.97),
              new THREE.MeshBasicMaterial({ map: texture, transparent: true }),
            );
            face.position.set(layer.x, layer.y, depth + 0.053);
            threeState.rootGroup.add(face);
          });
      }

      function renderAll() {
        renderStaticText();
        renderPropertyPanel();
        renderLayerList();
        refreshFabricOverlays();
        buildPreviewScene();
        setStatus(appState.status || t("status.ready"));
      }

      async function setImageFromDataUrl(dataUrl) {
        const image = new Image();
        await new Promise((resolve, reject) => {
          image.onload = resolve;
          image.onerror = reject;
          image.src = dataUrl;
        });

        appState.sourceImageUrl = dataUrl;
        appState.sourceImage = image;
        appState.imagePlacement = getContainPlacement(image.width, image.height, CANVAS_WIDTH, CANVAS_HEIGHT);
        appState.layers = [];
        appState.selectedLayerId = null;
        appState.history = [];
        appState.future = [];
        appState.status = t("status.imported");

        if (backgroundFabricImage) {
          fabricCanvas.remove(backgroundFabricImage);
          backgroundFabricImage = null;
        }
        clearOverlayRects();
        removeActiveSelection();

        await new Promise((resolve) => {
          fabric.Image.fromURL(
            dataUrl,
            (fabricImage) => {
              fabricImage.set({
                left: appState.imagePlacement.left,
                top: appState.imagePlacement.top,
                selectable: false,
                evented: false,
                scaleX: appState.imagePlacement.width / fabricImage.width,
                scaleY: appState.imagePlacement.height / fabricImage.height
              });
              backgroundFabricImage = fabricImage;
              fabricCanvas.add(fabricImage);
              fabricImage.sendToBack();
              fabricCanvas.requestRenderAll();
              resolve();
            },
            { crossOrigin: "anonymous" },
          );
        });

        renderAll();
      }

      async function importImageFile(file) {
        if (!file || !file.type.startsWith("image/")) {
          return;
        }
        const reader = new FileReader();
        reader.onload = async () => {
          if (typeof reader.result === "string") {
            await setImageFromDataUrl(reader.result);
          }
        };
        reader.readAsDataURL(file);
      }

      function pointerInsideImage(pointer) {
        const placement = appState.imagePlacement;
        if (!placement) {
          return false;
        }
        return (
          pointer.x >= placement.left &&
          pointer.x <= placement.left + placement.width &&
          pointer.y >= placement.top &&
          pointer.y <= placement.top + placement.height
        );
      }

      function addLayerFromSelection(selectionRect) {
        if (!appState.sourceImage || !appState.imagePlacement) {
          return;
        }

        const placement = appState.imagePlacement;
        const sourceX = Math.round(((selectionRect.left - placement.left) / placement.width) * placement.originalWidth);
        const sourceY = Math.round(((selectionRect.top - placement.top) / placement.height) * placement.originalHeight);
        const sourceWidth = Math.max(1, Math.round((selectionRect.width / placement.width) * placement.originalWidth));
        const sourceHeight = Math.max(1, Math.round((selectionRect.height / placement.height) * placement.originalHeight));

        const cropCanvas = document.createElement("canvas");
        cropCanvas.width = sourceWidth;
        cropCanvas.height = sourceHeight;
        const context = cropCanvas.getContext("2d");
        if (!context) {
          return;
        }

        context.drawImage(
          appState.sourceImage,
          sourceX,
          sourceY,
          sourceWidth,
          sourceHeight,
          0,
          0,
          sourceWidth,
          sourceHeight,
        );

        const textureUrl = cropCanvas.toDataURL("image/png");
        const centerX = selectionRect.left + selectionRect.width / 2;
        const centerY = selectionRect.top + selectionRect.height / 2;
        const relativeX = (centerX - placement.left) / placement.width;
        const relativeY = (centerY - placement.top) / placement.height;

        pushHistory();
        const layer = {
          id: makeId(),
          name: `Layer ${appState.layers.length + 1}`,
          textureUrl,
          visible: true,
          material: "glossy",
          thickness: 18,
          bevel: 6,
          radius: 16,
          left: selectionRect.left,
          top: selectionRect.top,
          width: selectionRect.width,
          height: selectionRect.height,
          width3d: (selectionRect.width / placement.width) * PHONE_WIDTH,
          height3d: (selectionRect.height / placement.height) * PHONE_HEIGHT,
          x: (relativeX - 0.5) * PHONE_WIDTH,
          y: (0.5 - relativeY) * PHONE_HEIGHT
        };

        appState.layers.push(layer);
        appState.selectedLayerId = layer.id;
        setActiveView("3d");
        renderAll();
      }

      fabricCanvas.on("mouse:down", (event) => {
        if (!appState.sourceImage || !appState.imagePlacement) {
          return;
        }

        const shouldSelect = appState.selectionMode || event.e.shiftKey;
        if (!shouldSelect) {
          return;
        }

        const pointer = fabricCanvas.getPointer(event.e);
        if (!pointerInsideImage(pointer)) {
          return;
        }

        removeActiveSelection();
        dragStartPoint = pointer;
        isSelecting = true;
        activeSelectionRect = new fabric.Rect({
          left: pointer.x,
          top: pointer.y,
          width: 0,
          height: 0,
          fill: "rgba(56,189,248,0.12)",
          stroke: "#38bdf8",
          strokeDashArray: [8, 6],
          selectable: false,
          evented: false,
          rx: 12,
          ry: 12
        });
        fabricCanvas.add(activeSelectionRect);
        activeSelectionRect.bringToFront();
      });

      fabricCanvas.on("mouse:move", (event) => {
        if (!isSelecting || !dragStartPoint || !activeSelectionRect || !appState.imagePlacement) {
          return;
        }
        const pointer = fabricCanvas.getPointer(event.e);
        const placement = appState.imagePlacement;
        const left = clamp(Math.min(dragStartPoint.x, pointer.x), placement.left, placement.left + placement.width);
        const top = clamp(Math.min(dragStartPoint.y, pointer.y), placement.top, placement.top + placement.height);
        const right = clamp(Math.max(dragStartPoint.x, pointer.x), placement.left, placement.left + placement.width);
        const bottom = clamp(Math.max(dragStartPoint.y, pointer.y), placement.top, placement.top + placement.height);
        activeSelectionRect.set({
          left,
          top,
          width: right - left,
          height: bottom - top
        });
        activeSelectionRect.setCoords();
        fabricCanvas.requestRenderAll();
      });

      fabricCanvas.on("mouse:up", () => {
        if (!isSelecting || !activeSelectionRect) {
          dragStartPoint = null;
          isSelecting = false;
          return;
        }
        const selection = {
          left: Number(activeSelectionRect.left || 0),
          top: Number(activeSelectionRect.top || 0),
          width: Number(activeSelectionRect.width || 0),
          height: Number(activeSelectionRect.height || 0)
        };

        dragStartPoint = null;
        isSelecting = false;
        removeActiveSelection();

        if (selection.width < 8 || selection.height < 8) {
          return;
        }

        addLayerFromSelection(selection);
      });

      function downloadBlob(blob, filename) {
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = filename;
        link.click();
        URL.revokeObjectURL(url);
      }

      function downloadCurrentSnapshot() {
        const source = appState.activeView === "3d"
          ? threeState.renderer.domElement.toDataURL("image/png")
          : document.getElementById("editorCanvas").toDataURL("image/png");
        const link = document.createElement("a");
        link.href = source;
        link.download = "3d-ui-forge-snapshot.png";
        link.click();
        appState.status = t("status.snapshot");
        renderAll();
      }

      function exportSingleHtml() {
        if (!appState.sourceImageUrl && appState.layers.length === 0) {
          alert(t("status.emptyExport"));
          return;
        }

        alert(t("alert.exportIntro"));
        const exportState = {
          lang: appState.lang,
          activeView: appState.activeView,
          selectionMode: appState.selectionMode,
          sourceImageUrl: appState.sourceImageUrl,
          layers: cloneLayers(appState.layers),
          selectedLayerId: appState.selectedLayerId
        };

        const html = document.documentElement.outerHTML.replace(
          '<script type="module">',
          `<script>window.__FORGE_STATE__=${JSON.stringify(exportState).replace(/</g, "\\u003c")};</script>\n    <script type="module">`,
        );

        downloadBlob(new Blob(["<!doctype html>\n" + html], { type: "text/html;charset=utf-8" }), "3d-ui-forge.html");
        appState.status = t("status.exported");
        renderAll();
      }

      function restoreFromImportState(importState) {
        if (!importState) {
          return;
        }
        appState.lang = importState.lang || "zh";
        appState.activeView = importState.activeView || "2d";
        appState.selectionMode = Boolean(importState.selectionMode);
        appState.selectedLayerId = importState.selectedLayerId || null;
        applyLanguage();
        setSelectionMode(appState.selectionMode);
        setActiveView(appState.activeView);

        if (importState.sourceImageUrl) {
          appState.skipHistory = true;
          setImageFromDataUrl(importState.sourceImageUrl).then(() => {
            appState.layers = Array.isArray(importState.layers) ? importState.layers : [];
            appState.selectedLayerId = importState.selectedLayerId || appState.layers.at(-1)?.id || null;
            appState.skipHistory = false;
            renderAll();
          });
        }
      }

      function undo() {
        if (!appState.history.length) {
          return;
        }
        appState.future.unshift(createSnapshot());
        const previous = appState.history.pop();
        appState.layers = cloneLayers(previous.layers);
        appState.selectedLayerId = previous.selectedLayerId;
        renderAll();
      }

      function redo() {
        if (!appState.future.length) {
          return;
        }
        appState.history.push(createSnapshot());
        const next = appState.future.shift();
        appState.layers = cloneLayers(next.layers);
        appState.selectedLayerId = next.selectedLayerId;
        renderAll();
      }

      elements.importBtn.addEventListener("click", () => elements.fileInput.click());
      elements.fileInput.addEventListener("change", (event) => {
        void importImageFile(event.target.files?.[0] || null);
      });

      elements.aiBtn.addEventListener("click", () => {
        alert(t("alert.ai"));
      });

      elements.manualBtn.addEventListener("click", () => {
        setSelectionMode(!appState.selectionMode);
      });

      elements.view2dBtn.addEventListener("click", () => setActiveView("2d"));
      elements.view3dBtn.addEventListener("click", () => setActiveView("3d"));
      elements.tab2dBtn.addEventListener("click", () => setActiveView("2d"));
      elements.tab3dBtn.addEventListener("click", () => setActiveView("3d"));
      elements.exportBtn.addEventListener("click", exportSingleHtml);
      elements.floatingExportBtn.addEventListener("click", exportSingleHtml);
      elements.snapshotBtn.addEventListener("click", downloadCurrentSnapshot);

      elements.langBtn.addEventListener("click", () => {
        setLanguage(appState.lang === "zh" ? "en" : "zh");
      });

      document.addEventListener("keydown", (event) => {
        const isMac = navigator.platform.toUpperCase().includes("MAC");
        const metaPressed = isMac ? event.metaKey : event.ctrlKey;
        if (metaPressed && event.key.toLowerCase() === "z" && !event.shiftKey) {
          event.preventDefault();
          undo();
        }
        if ((metaPressed && event.key.toLowerCase() === "y") || (metaPressed && event.shiftKey && event.key.toLowerCase() === "z")) {
          event.preventDefault();
          redo();
        }
      });

      ["dragenter", "dragover"].forEach((eventName) => {
        elements.dropZone.addEventListener(eventName, (event) => {
          event.preventDefault();
          elements.dropOverlay.classList.remove("hidden");
          elements.dropOverlay.classList.add("flex");
          elements.dropOverlayText.textContent = t("canvas.dropActive");
        });
      });

      ["dragleave", "drop"].forEach((eventName) => {
        elements.dropZone.addEventListener(eventName, (event) => {
          event.preventDefault();
          elements.dropOverlay.classList.add("hidden");
          elements.dropOverlay.classList.remove("flex");
          if (eventName === "drop") {
            void importImageFile(event.dataTransfer?.files?.[0] || null);
          }
        });
      });

      initThree();
      applyLanguage();
      setSelectionMode(false);
      setActiveView("2d");
      setStatus(t("status.ready"));
      renderAll();

      if (window.__FORGE_STATE__) {
        restoreFromImportState(window.__FORGE_STATE__);
      }
    </script>
  </body>
</html>
