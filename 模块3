<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>3D UI Forge - Pure HTML</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>
    <style>
      html,
      body {
        margin: 0;
        min-height: 100%;
        background: #09090b;
      }

      body {
        color: #fafafa;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
      }

      canvas {
        touch-action: none;
      }

      .range {
        width: 100%;
        accent-color: #38bdf8;
      }

      .glass-card {
        background: rgba(24, 24, 27, 0.86);
        backdrop-filter: blur(16px);
      }
    </style>
  </head>
  <body class="bg-zinc-950 text-zinc-50">
    <div id="app" class="min-h-screen bg-[radial-gradient(circle_at_top,_rgba(56,189,248,0.12),_transparent_26%)]">
      <header class="fixed inset-x-0 top-0 z-50 border-b border-zinc-800/80 bg-zinc-950/90 backdrop-blur">
        <div class="mx-auto flex max-w-[1800px] flex-wrap items-center gap-3 px-4 py-3">
          <div class="mr-auto">
            <div class="text-lg font-semibold tracking-tight" data-i18n="app.title">3D UI Forge</div>
            <div class="text-xs text-zinc-400" data-i18n="app.subtitle">伪3D UI 交互设计工具</div>
          </div>

          <div class="flex flex-wrap gap-2">
            <button
              id="importBtn"
              class="rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800"
              data-i18n="toolbar.import"
            >
              📤 导入原型图
            </button>
            <button
              id="aiBtn"
              class="rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800"
              data-i18n="toolbar.ai"
            >
              ✨ AI 一键识别
            </button>
            <button
              id="manualBtn"
              class="rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800"
              data-i18n="toolbar.manualSelect"
            >
              ⬛ 手动框选
            </button>
            <button
              id="view2dBtn"
              class="rounded-xl border border-sky-500 bg-sky-500 px-4 py-2 text-sm text-white transition hover:bg-sky-400"
              data-i18n="toolbar.editor2d"
            >
              2D 编辑器
            </button>
            <button
              id="view3dBtn"
              class="rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800"
              data-i18n="toolbar.preview3d"
            >
              3D 预览
            </button>
            <button
              id="exportBtn"
              class="rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800"
              data-i18n="toolbar.export"
            >
              📦 导出单文件
            </button>
            <button
              id="langBtn"
              class="rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800"
            >
              🌐 ZH
            </button>
          </div>

          <input id="fileInput" type="file" accept="image/*" class="hidden" />
        </div>
      </header>

      <main class="mx-auto max-w-[1800px] px-4 pb-28 pt-24">
        <section class="glass-card mb-4 rounded-2xl border border-zinc-800 p-4">
          <div class="mb-2 text-sm font-semibold text-zinc-100" data-i18n="usage.title">使用说明 / How To Use</div>
          <div class="text-sm leading-6 text-zinc-300" id="usageText"></div>
        </section>

        <div class="grid gap-4 xl:grid-cols-[300px_minmax(0,1fr)_320px]">
          <aside class="glass-card rounded-2xl border border-zinc-800">
            <div class="border-b border-zinc-800 p-5">
              <div class="text-base font-semibold" data-i18n="panels.properties">属性面板</div>
              <div class="mt-2 text-sm text-zinc-400" id="propertyDescription"></div>
            </div>
            <div class="p-5" id="propertyPanel"></div>
          </aside>

          <section class="min-w-0">
            <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
              <div class="flex gap-2">
                <button
                  id="tab2dBtn"
                  class="rounded-xl border border-sky-500 bg-sky-500 px-4 py-2 text-sm text-white transition hover:bg-sky-400"
                  data-i18n="toolbar.editor2d"
                >
                  2D 编辑器
                </button>
                <button
                  id="tab3dBtn"
                  class="rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800"
                  data-i18n="toolbar.preview3d"
                >
                  3D 预览
                </button>
              </div>

              <div class="flex flex-wrap gap-2">
                <span class="rounded-full border border-zinc-800 bg-zinc-900 px-3 py-1 text-xs text-zinc-300" data-i18n="tips.shift">
                  Shift + 拖拽
                </span>
                <span class="rounded-full border border-zinc-800 bg-zinc-900 px-3 py-1 text-xs text-zinc-300" data-i18n="tips.manual">
                  手动框选
                </span>
                <span class="rounded-full border border-zinc-800 bg-zinc-900 px-3 py-1 text-xs text-zinc-300" data-i18n="tips.sync">
                  实时同步
                </span>
              </div>
            </div>

            <section id="editor2dSection" class="glass-card rounded-2xl border border-zinc-800">
              <div class="border-b border-zinc-800 p-5">
                <div class="text-base font-semibold" data-i18n="canvas.title">2D 编辑画布</div>
                <div class="mt-2 text-sm text-zinc-400" data-i18n="canvas.subtitle">
                  上传 Figma 截图、手绘稿或设计图后，可按住 Shift + 拖拽框选元素。
                </div>
              </div>
              <div class="p-5">
                <div class="mb-3 flex flex-wrap items-center justify-between gap-3 text-sm text-zinc-400">
                  <div id="canvasStateText"></div>
                  <div id="canvasHintText"></div>
                </div>

                <div
                  id="dropZone"
                  class="relative overflow-hidden rounded-2xl border border-zinc-800 bg-[#050508] p-3 transition"
                >
                  <div class="overflow-auto rounded-xl border border-zinc-800 bg-zinc-950/60 p-3">
                    <canvas id="editorCanvas" width="920" height="560" class="mx-auto block max-w-full rounded-xl"></canvas>
                  </div>

                  <div
                    id="dropOverlay"
                    class="pointer-events-none absolute inset-0 hidden items-center justify-center bg-sky-500/10 backdrop-blur-sm"
                  >
                    <div class="rounded-2xl border border-sky-500/50 bg-zinc-950/90 px-8 py-6 text-center shadow-2xl">
                      <div class="text-sm font-medium text-zinc-100" id="dropOverlayText"></div>
                      <div class="mt-2 text-xs text-zinc-500" data-i18n="canvas.dropHint">
                        支持拖拽上传图片，也支持点击顶部导入按钮。
                      </div>
                    </div>
                  </div>

                  <div
                    id="emptyCanvasOverlay"
                    class="pointer-events-none absolute inset-0 flex items-center justify-center"
                  >
                    <div class="rounded-2xl border border-dashed border-zinc-700 bg-zinc-950/90 px-8 py-6 text-center shadow-2xl">
                      <div class="text-sm font-medium text-zinc-100" data-i18n="canvas.empty">
                        把设计图拖进来，或者点击顶部按钮导入。
                      </div>
                      <div class="mt-2 text-xs text-zinc-500" data-i18n="canvas.dropHint">
                        支持拖拽上传图片，也支持点击顶部导入按钮。
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <section id="preview3dSection" class="glass-card hidden rounded-2xl border border-zinc-800">
              <div class="border-b border-zinc-800 p-5">
                <div class="text-base font-semibold" data-i18n="preview.title">3D 预览</div>
                <div class="mt-2 text-sm text-zinc-400" data-i18n="preview.subtitle">
                  可拖拽旋转、缩放查看伪3D界面。
                </div>
              </div>
              <div class="relative h-[680px] overflow-hidden rounded-b-2xl bg-[radial-gradient(circle_at_top,_rgba(56,189,248,0.12),_rgba(9,9,11,1)_38%)]">
                <div id="threeContainer" class="h-full w-full"></div>
                <div
                  id="emptyPreviewOverlay"
                  class="pointer-events-none absolute inset-0 flex items-center justify-center"
                >
                  <div class="rounded-2xl border border-zinc-800 bg-zinc-950/85 px-8 py-6 text-center text-sm text-zinc-300 backdrop-blur">
                    <span data-i18n="preview.empty">导入图片后，这里会生成带厚度与圆角的 3D 预览。</span>
                  </div>
                </div>
              </div>
            </section>
          </section>

          <aside class="glass-card rounded-2xl border border-zinc-800">
            <div class="border-b border-zinc-800 p-5">
              <div class="text-base font-semibold" data-i18n="panels.layers">图层列表</div>
              <div class="mt-2 text-sm text-zinc-400" id="layerSummary"></div>
            </div>
            <div class="p-5" id="layerList"></div>
          </aside>
        </div>
      </main>

      <div class="fixed bottom-6 right-6 z-50 w-[min(440px,calc(100vw-32px))] xl:w-[420px]">
        <div class="glass-card rounded-2xl border border-zinc-800 shadow-2xl shadow-black/40">
          <div class="border-b border-zinc-800 p-5">
            <div class="text-base font-semibold" data-i18n="panels.export">导出</div>
            <div class="mt-2 text-sm text-zinc-400" id="statusText"></div>
          </div>
          <div class="flex flex-wrap gap-3 p-5">
            <button
              id="floatingExportBtn"
              class="rounded-xl border border-sky-500 bg-sky-500 px-4 py-2 text-sm text-white transition hover:bg-sky-400"
              data-i18n="toolbar.export"
            >
              📦 导出单文件
            </button>
            <button
              id="snapshotBtn"
              class="rounded-xl border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800"
              data-i18n="toolbar.snapshot"
            >
              🖼 导出截图
            </button>
          </div>
        </div>
      </div>
    </div>

